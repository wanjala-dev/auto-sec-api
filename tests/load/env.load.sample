# Copy this file to tests/load/.env.load (gitignored) and fill in real values.
#
# LOAD_TARGET defaults to "local". To run against demo, explicitly set LOAD_TARGET=demo.
# This is intentional friction — a misfired load run must not accidentally hit demo.

LOAD_TARGET=local
LOAD_PROFILE=smoke

LOAD_LOCAL_BASE_URL=http://localhost:8000
LOAD_DEMO_BASE_URL=https://api.wanjala.art

# Seeded by `python manage.py seed_load_test_user` (in components/shared_platform/cli/management/commands/).
# Defaults below match the command's defaults; override via LOAD_TEST_EMAIL / LOAD_TEST_PASSWORD env vars at seed time.
LOAD_SMOKE_EMAIL=loadtest@wanjala.local
LOAD_SMOKE_PASSWORD=loadtest-dev-only-password

# Optional. If unset, the workspace scenario lists workspaces and picks the first.
# The seed command prints the workspace_id; copy it here for deterministic targeting.
# LOAD_SMOKE_WORKSPACE_ID=00000000-0000-0000-0000-000000000000

LOAD_REQUEST_TIMEOUT_S=10.0
LOAD_ACCESS_TOKEN_REFRESH_BUFFER_S=60
