# RAG eval harness configuration.
# Copy this file to .env.eval (gitignored) and edit for your environment.
# Both .env.eval and reports/ are gitignored — judge LLM costs are real,
# we don't want stray runs landing in the repo.

# ── Target ────────────────────────────────────────────────────────────
# `local` runs against http://localhost:8000 (your Docker stack).
# `demo`  runs against https://api.wanjala.art (the deployed demo).
EVAL_TARGET=local

# ── Workspace ─────────────────────────────────────────────────────────
# UUID of the workspace the eval prompts target. For the Zaylan demo
# workspace, find it locally with:
#   docker exec compose-web-1 python manage.py shell -c \
#     "from infrastructure.persistence.workspaces.models import Workspace; \
#      print(Workspace.objects.get(workspace_name='Zaylan').id)"
EVAL_WORKSPACE_UUID=

# UUID of the founder user (eval runs as workspace owner). Find with:
#   docker exec compose-web-1 python manage.py shell -c \
#     "from django.contrib.auth import get_user_model; \
#      print(get_user_model().objects.get(email='founder@zaylan.demo').id)"
EVAL_USER_UUID=

# ── Judge LLM ─────────────────────────────────────────────────────────
# Model the harness uses to score Faithfulness + Answer Relevancy +
# Context Precision. Default is gpt-4o-mini for cost. Pin temperature
# to 0 for reproducibility across runs.
EVAL_JUDGE_MODEL=gpt-4o-mini
EVAL_JUDGE_TEMPERATURE=0.0
EVAL_JUDGE_MAX_TOKENS=1024

# ── Chat model under test ─────────────────────────────────────────────
# Leave blank to use the workspace's configured chat model. Override
# only for A/B experiments comparing models.
# EVAL_CHAT_MODEL=

# ── Run controls ──────────────────────────────────────────────────────
# Set to true to skip judge LLM calls (cheap pipeline-only check).
EVAL_COLLECT_ONLY=false

# Set to true + REPLAY_RUN_PATH to score an existing collected run.
EVAL_SCORE_ONLY=false
# EVAL_REPLAY_RUN_PATH=tests/eval/rag/reports/run-20260610-103000.json

# Limit run to the first N prompts (0 = all 30).
EVAL_MAX_PROMPTS=0

# Comma-separated category filter (empty = all). Categories:
# identity, transactional, ambiguous.
# EVAL_ONLY_CATEGORIES=identity,transactional
